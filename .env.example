# App
PROJECT_NAME="Instagram Auto Reply System"
API_V1_STR="/api/v1"
SECRET_KEY="changethis"
ENV="production" # production, development

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=insta_bot_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:changethis@localhost:5432/insta_bot_db

